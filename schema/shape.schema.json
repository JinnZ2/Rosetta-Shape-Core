{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosetta-shape-core/schema/shape.schema.json",
  "title": "Rosetta Shape",
  "type": "object",
  "required": ["id", "name", "families"],
  "properties": {
    "id": { "type": "string", "pattern": "^SHAPE\\.[A-Z0-9_]+$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "faces": { "type": ["integer", "null"] },
    "edges": { "type": ["integer", "null"] },
    "vertices": { "type": ["integer", "null"] },
    "families": { "type": "array", "items": { "type": "string" } },
    "equation_families": { "type": "array", "items": { "type": "string" } },
    "principles": { "type": "array", "items": { "type": "string" } },
    "shape_class": {
      "type": "string",
      "enum": ["platonic", "emergent", "derived"],
      "description": "Shape classification. Platonic = static solid. Emergent = dynamic form arising from field interactions. Derived = constructed from other shapes."
    },
    "derived_from": { "type": "array", "items": { "type": "string" } },
    "polyhedral": {
      "type": "object",
      "required": ["maps_to"],
      "properties": {
        "maps_to": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "bridges": {
      "type": "object",
      "properties": {
        "sensors": { "type": "array", "items": { "type": "string" } },
        "glyphs": { "type": "array", "items": { "type": "string" } },
        "protocols": { "type": "array", "items": { "type": "string" } },
        "defenses": { "type": "array", "items": { "type": "string" } },
        "audit_glyphs": { "type": "array", "items": { "type": "string" } },
        "bridge_glyphs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "updated": { "type": "string" },
        "derived_from_event": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "cross_repo": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "felt_anchor": { "type": "object" },
    "PAD_profile": { "type": "object" },
    "decay_model": { "type": "object" },
    "ontology_links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "to": { "type": "string" },
          "type": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "open_questions": { "type": "array" },
    "noise_signature": { "type": "array" }
  },
  "additionalProperties": false
}
